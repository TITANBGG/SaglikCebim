{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Projeyi Başlat (Tam Kurulum)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/Kod/saglikcebim/setup.ps1"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "🛑 Projeyi Durdur",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/Kod/saglikcebim/stop.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "📋 Durumu Kontrol Et",
      "type": "shell",
      "command": "docker-compose",
      "args": [
        "-f",
        "${workspaceFolder}/Kod/saglikcebim/docker-compose.prod.yml",
        "ps"
      ],
      "problemMatcher": []
    },
    {
      "label": "📜 Logları Göster",
      "type": "shell",
      "command": "docker-compose",
      "args": [
        "-f",
        "${workspaceFolder}/Kod/saglikcebim/docker-compose.prod.yml",
        "logs",
        "-f"
      ],
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "🔄 Servisleri Yeniden Başlat",
      "type": "shell",
      "command": "docker-compose",
      "args": [
        "-f",
        "${workspaceFolder}/Kod/saglikcebim/docker-compose.prod.yml",
        "restart"
      ],
      "problemMatcher": []
    }
  ]
}
